{
  "name": "raindrop-mcp",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "./dist/main.cjs",
  "module": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/main.d.ts",
        "default": "./dist/main.js"
      },
      "require": {
        "types": "./dist/main.d.cts",
        "default": "./dist/main.cjs"
      }
    }
  },
  "bin": {
    "raindrop-mcp": "./dist/main.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "test": "echo \"Error: no test specified\" && exit 1",
    "inspector": "npx @modelcontextprotocol/inspector node dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --no-warn-ignored",
    "lint:fix": "eslint . --fix --no-warn-ignored",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "lefthook install",
    "inspect": "mcp-inspector node dist/main.js",
    "check:branch": "bash scripts/check-branch-name.sh"
  },
  "keywords": [
    "mcp",
    "raindrop",
    "bookmarks",
    "model-context-protocol"
  ],
  "author": "Kunal Singh",
  "license": "MIT",
  "packageManager": "pnpm@10.17.1",
  "devDependencies": {
    "@kunal-singh/commitlint-config": "latest",
    "@kunal-singh/eslint-config": "latest",
    "@kunal-singh/prettier-config": "latest",
    "@kunal-singh/typescript-config": "latest",
    "@modelcontextprotocol/inspector": "^0.20.0",
    "@types/node": "latest",
    "eslint": "latest",
    "lefthook": "^2.1.4",
    "lint-staged": "^16.3.3",
    "prettier": "latest",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  },
  "lint-staged": {
    "**/*.{ts,js,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "**/*.ts": [
      "eslint --cache --fix"
    ]
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
